
{
  "compilerOptions": {
    "jsx": "preserve",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    
   "outDir" : "./dist",
    "lib": [
      "ESNext",
      "ESNext.AsyncIterable",
      "DOM"
    ],
    "esModuleInterop": true,
    "allowJs": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "baseUrl": "./src",
    "paths": {
      "~/*": [
        "./*"
      ],
      "@/*": ["*"]
    },

    "types": [
      "@types/node"
    ]
  },
       "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    ".nuxt",
    "dist"
  ]
}